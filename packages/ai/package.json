{
  "name": "@tartarus/ai",
  "version": "0.1.0",
  "description": "Enemy AI: factory, Yuka steering, spawning, death systems",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./spawning": {
      "import": "./dist/spawning/index.js",
      "types": "./dist/spawning/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tartarus/core": "workspace:*",
    "pixi.js": "^8.6.0",
    "yuka": "^0.7.8"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.0",
    "happy-dom": "^20.4.0"
  }
}
